# Copier ce fichier en ".env" et adapter les valeurs

PORT=4000

# Connexion PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=stock_app
DB_USER=postgres
DB_PASSWORD=postgres

# Clé secrète JWT (changer en production)
JWT_SECRET=change_this_super_secret_key
JWT_EXPIRES_IN=7d

# Identifiants du compte de démonstration créé par "npm run seed" (facultatif)
SEED_ADMIN_EMAIL=demo@stock.local
SEED_ADMIN_PASSWORD=demo1234
SEED_ADMIN_NAME=Compte de démonstration

# --- Paiement Premium (Orange Money / MTN Mobile Money) ---
# Laisser le fournisseur non configuré désactive le paiement en ligne (le bouton
# "Passer Premium" affichera un message d'indisponibilité ; l'activation manuelle
# en base reste toujours possible).

# Fournisseur actif : "monetbil" ou "cinetpay"
PAYMENT_PROVIDER=monetbil

# Prix de l'abonnement Premium en FCFA
SUBSCRIPTION_PRICE_XAF=2000

# --- Monetbil ---
# Obtenir votre service_key sur https://www.monetbil.com/services après inscription marchande.
MONETBIL_SERVICE_KEY=
MONETBIL_COUNTRY=CM
# URL PUBLIQUE de votre backend déployé (Monetbil doit pouvoir l'appeler depuis internet) :
MONETBIL_NOTIFY_URL=https://votre-domaine-backend.exemple/api/payments/notify
MONETBIL_RETURN_URL=http://localhost:5173/premium/retour

# --- CinetPay (alternative) ---
# Obtenir ces identifiants sur https://cinetpay.com après inscription marchande.
CINETPAY_API_KEY=
CINETPAY_SITE_ID=
CINETPAY_NOTIFY_URL=https://votre-domaine-backend.exemple/api/payments/notify
CINETPAY_RETURN_URL=http://localhost:5173/premium/retour

